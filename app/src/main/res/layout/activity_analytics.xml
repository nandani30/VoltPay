<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="20dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            android:rotation="180"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analytics"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2A" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ProgressBar
            android:id="@+id/pbLoading"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="#2ED573"
            tools:visibility="gone" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/svContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <!-- This Week Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1A1A1A"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THIS WEEK"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:textAllCaps="true"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Spent"
                                android:textSize="12sp"
                                android:textColor="#555555" />
                            <TextView
                                android:id="@+id/tvWeekSpent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#FF4444" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Received"
                                android:textSize="12sp"
                                android:textColor="#555555" />
                            <TextView
                                android:id="@+id/tvWeekReceived"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#2ED573" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvWeekTxCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 transactions"
                        android:textSize="12sp"
                        android:textColor="#555555"
                        android:layout_marginTop="16dp" />
                </LinearLayout>

                <!-- This Month Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1A1A1A"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THIS MONTH"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:textAllCaps="true"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Spent"
                                android:textSize="12sp"
                                android:textColor="#555555" />
                            <TextView
                                android:id="@+id/tvMonthSpent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#FF4444" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Received"
                                android:textSize="12sp"
                                android:textColor="#555555" />
                            <TextView
                                android:id="@+id/tvMonthReceived"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#2ED573" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMonthLargest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Largest: ₹0"
                        android:textSize="13sp"
                        android:textColor="#A0A0A0"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:id="@+id/tvMonthAverage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Average: ₹0"
                        android:textSize="13sp"
                        android:textColor="#A0A0A0"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Bar Chart Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1A1A1A"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LAST 7 DAYS"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:textAllCaps="true"
                        android:layout_marginBottom="16dp" />
                        
                    <TextView
                        android:id="@+id/tvNoBarData"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No transactions in last 7 days"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp" />
                </LinearLayout>

                <!-- Pie Chart Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1A1A1A"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SENT VS RECEIVED"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:textAllCaps="true"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvNoPieData"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No data this month"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pieChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp" />
                </LinearLayout>

                <!-- Line Chart Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1A1A1A"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MONTHLY TREND"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:textAllCaps="true"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvNoLineData"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not enough data yet"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>
</LinearLayout>
