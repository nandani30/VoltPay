<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_app_gradient"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="20dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_back"
            android:rotation="180"
            android:tint="@color/textPrimary"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Analytics"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Period Selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/chipWeek"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This Week"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnPrimary"
            android:background="@drawable/bg_gradient_primary"
            android:paddingHorizontal="24dp"
            android:paddingVertical="10dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/chipMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This Month"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/textSecondary"
            android:background="@drawable/bg_glass_card"
            android:paddingHorizontal="24dp"
            android:paddingVertical="10dp"
            android:layout_marginStart="12dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/pbLoading"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:visibility="gone"
        android:indeterminateTint="@color/colorPrimary" />

    <ScrollView
        android:id="@+id/svContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="32dp">

            <!-- Summary Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <!-- Spent Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_glass_card"
                    android:padding="20dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spent"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tvTotalSpent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginTop="8dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_back"
                            android:rotation="90"
                            android:tint="@color/colorError" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Out"
                            android:textSize="11sp"
                            android:textColor="@color/colorError"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Received Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_glass_card"
                    android:padding="20dp"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Received"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tvTotalReceived"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginTop="8dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_back"
                            android:rotation="-90"
                            android:tint="@color/colorPrimary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="In"
                            android:textSize="11sp"
                            android:textColor="@color/colorPrimary"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Chart Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:layout_marginTop="24dp"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Activity"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

                <!-- Placeholder for Chart -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:background="@drawable/bg_glass_input"
                    android:layout_marginTop="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="[Chart]"
                        android:textColor="@color/textTertiary"
                        android:layout_gravity="center" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spent"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvWeekSpent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorError" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Received"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvWeekReceived"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorPrimary" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvWeekTxCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 transactions"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginTop="16dp" />
            </LinearLayout>

                <!-- This Month Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1A1A1A"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THIS MONTH"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:textAllCaps="true"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Spent"
                                android:textSize="12sp"
                                android:textColor="#555555" />
                            <TextView
                                android:id="@+id/tvMonthSpent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#FF4444" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Received"
                                android:textSize="12sp"
                                android:textColor="#555555" />
                            <TextView
                                android:id="@+id/tvMonthReceived"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#2ED573" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMonthLargest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Largest: ₹0"
                        android:textSize="13sp"
                        android:textColor="#A0A0A0"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:id="@+id/tvMonthAverage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Average: ₹0"
                        android:textSize="13sp"
                        android:textColor="#A0A0A0"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Bar Chart Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1A1A1A"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LAST 7 DAYS"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:textAllCaps="true"
                        android:layout_marginBottom="16dp" />
                        
                    <TextView
                        android:id="@+id/tvNoBarData"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No transactions in last 7 days"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp" />
                </LinearLayout>

                <!-- Pie Chart Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1A1A1A"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SENT VS RECEIVED"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:textAllCaps="true"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvNoPieData"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No data this month"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pieChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp" />
                </LinearLayout>

                <!-- Line Chart Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1A1A1A"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MONTHLY TREND"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:textAllCaps="true"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvNoLineData"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not enough data yet"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
</LinearLayout>
