<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="20dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            android:rotation="180"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Payment Request"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2A" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvRequesterName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="is requesting"
                android:textSize="14sp"
                android:textColor="#555555"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textSize="52sp"
                android:textStyle="bold"
                android:textColor="#2ED573"
                android:gravity="center"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tvNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="For dinner"
                android:textSize="14sp"
                android:textColor="#A0A0A0"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:textStyle="italic" />

            <!-- Expiry Pill -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="20dp">
                
                <TextView
                    android:id="@+id/tvExpiredMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Request expires in X hours"
                    android:textSize="12sp"
                    android:textColor="#2ED573"
                    android:background="#1A1A1A"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Details Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#1A1A1A"
                android:padding="20dp"
                android:layout_marginTop="32dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="From"
                    android:textSize="12sp"
                    android:textColor="#555555" />

                <TextView
                    android:id="@+id/tvRequesterUpiId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="upi@id"
                    android:textSize="13sp"
                    android:textColor="#A0A0A0"
                    android:gravity="end" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvExpiredBig"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THIS REQUEST HAS EXPIRED"
                android:textSize="13sp"
                android:textColor="#FF4444"
                android:textAllCaps="true"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2A" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPayNow"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="PAY NOW"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:backgroundTint="#2ED573"
            app:cornerRadius="0dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDecline"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="DECLINE"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="#FF4444"
            app:backgroundTint="#1A1A1A"
            app:strokeColor="#FF4444"
            app:strokeWidth="1dp"
            app:cornerRadius="0dp"
            app:elevation="0dp" />
    </LinearLayout>

</LinearLayout>
