<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_app_gradient">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="20dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_back"
            android:rotation="180"
            android:tint="@color/textPrimary"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Balance"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR BALANCE"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/textSecondary"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:gravity="center" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">
            
            <LinearLayout
                android:id="@+id/llBalanceContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="32dp"
                android:background="@drawable/bg_glass_card">
                
                <TextView
                    android:id="@+id/tvBalanceAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ --"
                    android:textSize="56sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>

                <View
                    android:layout_width="80dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_gradient_primary"
                    android:layout_marginTop="16dp" />

            </LinearLayout>
            
            <ProgressBar
                android:id="@+id/pbLoading"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/colorPrimary"/>
        </FrameLayout>

        <!-- Jio Warning -->
        <LinearLayout
            android:id="@+id/tvJioWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginTop="24dp"
            android:visibility="gone">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_alert"
                android:tint="@color/colorWarning" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Balance check not available on Jio"
                android:textSize="14sp"
                android:textColor="@color/colorWarning"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Manual Input Section -->
        <LinearLayout
            android:id="@+id/llManualInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@drawable/bg_glass_card"
            android:padding="24dp"
            android:layout_marginTop="24dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WHAT WAS YOUR BALANCE?"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/textSecondary"
                android:textAllCaps="true" />
                
            <EditText
                android:id="@+id/etManualBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:hint="0.00"
                android:textColorHint="@color/textTertiary"
                android:textColor="@color/textPrimary"
                android:textSize="32sp"
                android:textStyle="bold"
                android:background="@null"
                android:layout_marginTop="16dp" />
                
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@drawable/bg_gradient_primary"
                android:layout_marginTop="8dp" />
                
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveManualBalance"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Balance"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@color/colorOnPrimary"
                app:backgroundTint="@color/colorPrimary"
                app:cornerRadius="28dp"
                app:elevation="8dp"
                android:layout_marginTop="24dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
