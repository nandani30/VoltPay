<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_glass_card"
    android:paddingHorizontal="24dp"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="48dp"
        android:layout_height="6dp"
        android:background="@color/glassBorder"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your UPI ID"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Needed for QR code and payment requests"
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/etUpiId"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_glass_input"
        android:textColor="@color/textPrimary"
        android:textSize="18sp"
        android:hint="yourname@bankhandle"
        android:textColorHint="@color/textTertiary"
        android:paddingHorizontal="16dp"
        android:inputType="textEmailAddress" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@android:color/transparent"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveUpi"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Save and Continue"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:textColor="@color/colorOnPrimary"
        app:backgroundTint="@color/colorPrimary"
        app:cornerRadius="32dp"
        app:elevation="8dp" />

</LinearLayout>
