<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1A1A"
    android:paddingHorizontal="24dp"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#333333"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save Transaction"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Confirm details to add to your history"
        android:textSize="13sp"
        android:textColor="#555555"
        android:layout_marginBottom="28dp" />

    <!-- UPI ID -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RECIPIENT UPI ID"
        android:textSize="11sp"
        android:textColor="#A0A0A0"
        android:textAllCaps="true" />
    <EditText
        android:id="@+id/etUpi"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@null"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:hint="name@bank"
        android:textColorHint="#333333"
        android:inputType="textEmailAddress" />
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="20dp" />

    <!-- Amount -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AMOUNT (₹)"
        android:textSize="11sp"
        android:textColor="#A0A0A0"
        android:textAllCaps="true" />
    <EditText
        android:id="@+id/etAmount"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@null"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:inputType="numberDecimal"
        android:hint="0.00"
        android:textColorHint="#333333" />
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="20dp" />

    <!-- Reference -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="UPI REFERENCE (OPTIONAL)"
        android:textSize="11sp"
        android:textColor="#A0A0A0"
        android:textAllCaps="true" />
    <EditText
        android:id="@+id/etRef"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@null"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:inputType="number"
        android:hint="Leave blank if unknown"
        android:textColorHint="#333333" />
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmSave"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="CONFIRM AND SAVE"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:backgroundTint="#2ED573"
        app:cornerRadius="0dp"
        app:elevation="0dp" />

</LinearLayout>
