<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_glass_card"
    android:paddingHorizontal="24dp"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="48dp"
        android:layout_height="6dp"
        android:background="@color/glassBorder"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save Transaction"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Confirm details to add to your history"
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="32dp" />

    <!-- UPI ID -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RECIPIENT UPI ID"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/textSecondary"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />
    <EditText
        android:id="@+id/etUpi"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_glass_input"
        android:textColor="@color/textPrimary"
        android:textSize="16sp"
        android:hint="name@bank"
        android:textColorHint="@color/textTertiary"
        android:paddingHorizontal="16dp"
        android:inputType="textEmailAddress" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/transparent"
        android:layout_marginBottom="24dp" />

    <!-- Amount -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AMOUNT (₹)"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/textSecondary"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />
    <EditText
        android:id="@+id/etAmount"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_glass_input"
        android:textColor="@color/textPrimary"
        android:textSize="16sp"
        android:inputType="numberDecimal"
        android:hint="0.00"
        android:textColorHint="@color/textTertiary"
        android:paddingHorizontal="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/transparent"
        android:layout_marginBottom="24dp" />

    <!-- Reference -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="UPI REFERENCE (OPTIONAL)"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/textSecondary"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />
    <EditText
        android:id="@+id/etRef"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_glass_input"
        android:textColor="@color/textPrimary"
        android:textSize="16sp"
        android:inputType="number"
        android:hint="Leave blank if unknown"
        android:textColorHint="@color/textTertiary"
        android:paddingHorizontal="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/transparent"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmSave"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Confirm and Save"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:textColor="@color/colorOnPrimary"
        app:backgroundTint="@color/colorPrimary"
        app:cornerRadius="32dp"
        app:elevation="8dp" />

</LinearLayout>
