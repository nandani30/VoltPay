<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fitsSystemWindows="true">

    <!-- Progress dots -->
    <LinearLayout
        android:id="@+id/progressDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="#2ED573" android:layout_marginHorizontal="4dp"/>
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="#333333" android:layout_marginHorizontal="4dp"/>
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="#333333" android:layout_marginHorizontal="4dp"/>
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="#333333" android:layout_marginHorizontal="4dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvSimTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="40dp"
        android:text="Select your SIM"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/progressDots" />

    <TextView
        android:id="@+id/tvSimSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:text="Choose the SIM linked to your bank account"
        android:textSize="14sp"
        android:textColor="#A0A0A0"
        app:layout_constraintTop_toBottomOf="@id/tvSimTitle" />

    <!-- SIM list container (Dynamically populated, but here's the container) -->
    <LinearLayout
        android:id="@+id/simListContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvSimSubtitle" />

    <!-- Manual Phone Number Input (Hidden by default) -->
    <LinearLayout
        android:id="@+id/llManualPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/simListContainer">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="We couldn't detect the number for this SIM."
            android:textSize="13sp"
            android:textColor="#A0A0A0"
            android:layout_marginBottom="8dp" />
            
        <EditText
            android:id="@+id/etManualPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:inputType="phone"
            android:hint="Phone number (e.g. 9876543210)"
            android:textColorHint="#333333"
            android:paddingBottom="8dp" />
            
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#2ED573" />
    </LinearLayout>

    <!-- Jio Warning Card -->
    <LinearLayout
        android:id="@+id/tvJioWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A1A1A"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/llManualPhone">
        
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_alert"
            android:tint="#2ED573" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jio does not support offline payments. You can still use QR and contacts."
            android:textSize="13sp"
            android:textColor="#2ED573"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="48dp"
        android:text="CONTINUE"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:enabled="false"
        app:backgroundTint="#2ED573"
        app:cornerRadius="0dp"
        app:elevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
